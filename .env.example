# PostgreSQL Configuration
POSTGRES_VERSION=16rc1-alpine3.18
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_PORT=5432
POSTGRES_DB=FastArena
POSTGRES_USER=postgres

# PgAdmin Configuration
PGADMIN_VERSION=7.5
PGADMIN_PORT=5055
PGADMIN_DEFAULT_EMAIL=your_email@example.com
PGADMIN_DEFAULT_PASSWORD=your_pgadmin_password_here
PGADMIN_CONFIG_SERVER_MODE=False

# FastArena Application Configuration
FASTARENA_BACKEND_VERSION=0.0.1
FASTARENA_FRONTEND_VERSION=0.0.1

# Application Ports
APP_HTTP_PORT=80
APP_HTTPS_PORT=443
FRONTEND_PORT=8080

# Database Connection Details
DB_HOST=fa_postgres
